{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "portfolio: dev server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/ilegene3"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "vite",
          "endsPattern": "ready in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "portfolio: open in Cursor",
      "type": "vscode",
      "command": "simpleBrowser.show",
      "args": ["http://localhost:5173"]
    },
    {
      "label": "Portfolio Live Preview (in Cursor)",
      "dependsOn": ["portfolio: dev server", "portfolio: open in Cursor"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
